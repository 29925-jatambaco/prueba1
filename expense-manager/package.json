{
  "name": "expense-manager",
  "version": "1.0.0",
  "description": "Gestor de Gastos Personales - Aplicación web moderna con Web Components y Node.js",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "test": "jest --coverage --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js",
    "format": "prettier --write \"**/*.js\"",
    "init-db": "node scripts/init-db.js",
    "seed": "node scripts/seed.js",
    "postinstall": "node scripts/init-db.js || true"
  },
  "keywords": [
    "expense-manager",
    "web-components",
    "nodejs",
    "express",
    "sqlite"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "eslint": "^10.3.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
